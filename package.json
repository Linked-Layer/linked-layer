{
  "name": "linked-layer",
  "version": "0.1.0",
  "private": true,
  "description": "Linked Layer ($LINKED) — token-gated shared-memory / context layer for teams and agents (MCP + Context API)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "vite build apps/web",
    "build:backend": "tsc -b",
    "web": "pnpm --filter @linked/web dev",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "pnpm --filter @recall/db db:generate",
    "db:migrate": "pnpm --filter @recall/db db:migrate",
    "seed": "tsx packages/worker/src/seed.ts",
    "key:create": "tsx packages/worker/src/keygen.ts",
    "api": "tsx packages/api/src/server.ts",
    "worker": "tsx packages/worker/src/index.ts",
    "mcp": "tsx packages/mcp/src/server.ts",
    "dev": "concurrently -n api,worker -c blue,green \"pnpm api\" \"pnpm worker\""
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.0"
}
